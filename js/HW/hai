.project-box{
    width:200px;
    padding:20px;
    background:white;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,0.2);
    cursor:pointer;
    transition:all 0.4s ease;
    position:relative;
    overflow:hidden;
}

/* Before Animation */
.project-box::before{
    content:"";
    position:absolute;
    width:100%;
    height:100%;
    background:lightgray;
    left:-100%;
    top:0;
    transition:0.4s;
    z-index:0;
}

/* Hover effect */
.project-box:hover::before{
    left:0;
}

/* Text above animation */
.project-box h3,
.project-box p{
    position:relative;
    z-index:1;
}

/* Click color change */
.project-box.active{
    background:lightgray;
    color:white;
}


/* hover animation */
.btn:hover::before{
    left: 0;
}

.btn:hover{
    color: white;
}

